---
import Base from '../../layouts/Base.astro';
import Section from '../../components/Section.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../../lib/url';

const posts = (await getCollection('blog')).sort(
  (a, b) => +new Date(b.data.date) - +new Date(a.data.date),
);
const fmt = (d: Date) =>
  new Date(d).toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' });
---
<Base title="Blog" description="News, benchmarks and technical articles from Devito Codes.">
  <Section eyebrow="Blog" title="News & technical articles" class="pt-28">
    <div class="mt-12 divide-y divide-line/60">
      {posts.map((post) => (
        <article class="py-8 flex flex-col md:flex-row md:gap-8">
          <time class="font-mono text-xs text-muted md:w-32 shrink-0 pt-1">{fmt(post.data.date)}</time>
          <div>
            <h2 class="text-xl font-bold text-ink">
              <a href={withBase(`/blog/${post.id}`)} class="hover:text-accent transition-colors">{post.data.title}</a>
            </h2>
            {post.data.description && <p class="mt-2 text-muted leading-relaxed">{post.data.description}</p>}
            <div class="mt-3 flex flex-wrap gap-2">
              {post.data.tags.slice(0, 4).map((t) => (
                <span class="font-mono text-[11px] px-2 py-0.5 rounded border border-line text-muted">{t}</span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </Section>
</Base>
