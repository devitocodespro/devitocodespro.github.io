---
/*
 * DevitoHorizon product page — the complete Python FWI/imaging inversion SDK.
 * Content distilled from the DevitoHorizon whitepaper (June 2026).
 */
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';
import Button from '../components/Button.astro';
import CTA from '../components/CTA.astro';
import { withBase } from '../lib/url';

const adds = [
  { name: 'Misfits', body: 'Least-squares (L2), L1, Student’s-t, phase and envelope objectives, with normalization wrappers and a hook for user-supplied misfit/gradient pairs.' },
  { name: 'Optimizers', body: 'Spectral Projected Gradient, Projected Quasi-Newton (L-BFGS), a split-Bregman sparsity scheme and SciPy wrappers — all box-constrained.' },
  { name: 'Physics', body: 'Iso-acoustic, isotropic-elastic and TTI (elastic & acoustic) propagators, selected automatically from the model — plus a hook for user-supplied physics.' },
  { name: 'Workflow', body: 'Frequency continuation for multi-scale inversion, stochastic mini-batching over shots, and multi-parameter inversion with per-parameter bounds.' },
  { name: 'Conditioning & preprocessing', body: 'Water-bottom / datum / cone muting, illumination preconditioning, source-wavelet estimation, band-pass, AGC and normalization — applied consistently to observed and synthetic data.' },
  { name: 'Data & models', body: 'SEG-Y and Zarr shot data, HDF5/SEG-Y/Zarr models, streamed per shot for predictable memory use.' },
];
---
<Base title="DevitoHorizon" description="DevitoHorizon — a complete FWI and imaging inversion SDK in Python. Composable misfits, optimizers, preprocessing and multi-scale orchestration; wave-equation solves run on DevitoPRO.">
  {/* Hero */}
  <section class="bg-surface border-b border-line">
    <div class="container-x pt-28 pb-16 md:pt-32 md:pb-20">
      <p class="font-mono text-xs uppercase tracking-[0.18em] text-accent">DevitoHorizon · Python FWI &amp; imaging SDK</p>
      <h1 class="mt-5 max-w-4xl text-4xl md:text-6xl font-extrabold text-ink text-balance leading-[1.05]">
        A complete FWI &amp; imaging SDK — to configure, not build.
      </h1>
      <p class="mt-6 max-w-3xl text-lg md:text-xl text-muted leading-relaxed">
        DevitoHorizon is a collection of composable building blocks for seismic FWI and imaging that
        together form a complete inversion SDK — data handling, misfits, optimizers, preprocessing,
        gradient conditioning and multi-scale orchestration. It delegates the wave-equation solves to
        DevitoPRO, so a geophysics team can assemble a full FWI/RTM/LS-RTM workflow from tested,
        composable components.
      </p>
      <div class="mt-10 flex flex-wrap gap-3">
        <Button href="/contact" variant="primary">Book a technical call</Button>
        <Button href="/#stack" variant="ghost">See how the stack fits</Button>
      </div>
    </div>
  </section>

  {/* What it adds */}
  <Section
    id="capabilities"
    tone="base"
    eyebrow="What DevitoHorizon adds"
    title="The full workflow around the wave equation"
    intro="The same workflow runs as a composable Python API (Dataset, DevitoPhysics, Optimizer) or a command-line driver."
  >
    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {adds.map((a) => (
        <article class="card p-6">
          <h3 class="font-bold text-ink text-lg">{a.name}</h3>
          <p class="mt-3 text-muted leading-relaxed text-sm">{a.body}</p>
        </article>
      ))}
    </div>
  </Section>

  {/* Result figure */}
  <Section tone="surface" eyebrow="Worked example" title="End-to-end FWI on a public benchmark">
    <figure class="mt-10 card p-4 md:p-6">
      <img
        src={withBase('/images/devitohorizon-overthrust-fwi.png')}
        alt="Acoustic FWI on the SEG/EAGE Overthrust benchmark: from a smooth starting model the inversion recovers the faulted structure."
        loading="lazy"
        class="w-full h-auto rounded-md"
      />
      <figcaption class="mt-4 text-sm text-muted leading-relaxed">
        Acoustic FWI on the SEG/EAGE Overthrust benchmark, run end-to-end in DevitoHorizon: from a
        smooth start (left) the inversion recovers the faulted structure (right).
      </figcaption>
    </figure>
  </Section>

  {/* Design philosophy */}
  <Section
    tone="base"
    eyebrow="Design philosophy"
    title="Explicit, composable, swappable"
    intro="Components are wired together as first-class objects — no hidden state, no monolithic driver. Every major piece (misfit, optimizer, scheduler, data backend, gradient processor) is swappable through a small interface, so you can drop in a proprietary misfit, a custom I/O backend or an in-house optimizer without forking the core. The reference algorithms are short and readable — bridging method development and production."
  >
    <div class="mt-8">
      <p class="text-muted leading-relaxed max-w-3xl">
        Kernel performance and hardware portability belong to
        <a href={withBase('/devitopro')} class="text-accent font-semibold hover:underline">DevitoPRO</a>:
        DevitoHorizon generates no device code. Its parallelism is shot-level task scheduling — serial by
        default, or distributed with Dask — which composes with, and is distinct from, DevitoPRO's
        per-device acceleration.
      </p>
    </div>
  </Section>

  <CTA />
</Base>
