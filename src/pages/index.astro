---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import LogoBar from '../components/LogoBar.astro';
import Trilemma from '../components/Trilemma.astro';
import Solution from '../components/Solution.astro';
import Benchmarks from '../components/Benchmarks.astro';
import UseCases from '../components/UseCases.astro';
import Section from '../components/Section.astro';
import FeatureHighlights from '../components/FeatureHighlights.astro';
import CaseStudies from '../components/CaseStudies.astro';
import TeamTeaser from '../components/TeamTeaser.astro';
import CTA from '../components/CTA.astro';
import Button from '../components/Button.astro';
import { featureIntro } from '../data/features';
import { getCollection } from 'astro:content';

// Drafts hidden from listings; URLs still resolve via the [...slug] route.
const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => +new Date(b.data.date) - +new Date(a.data.date));
---
<Base>
  <Hero />
  <LogoBar />
  <Trilemma tone="surface" />
  <Solution tone="base" />
  <Benchmarks tone="surface" />
  <UseCases tone="base" />
  <Section
    id="compare"
    tone="surface"
    eyebrow="What's in DevitoPRO"
    title="Everything in Devito, plus what production needs."
    intro={featureIntro}
  >
    <div class="mt-10"><FeatureHighlights condensed={true} /></div>
    <div class="mt-8 flex flex-wrap gap-3">
      <Button href="/features" variant="primary">All features</Button>
      <Button href="/features#compare" variant="ghost">Compare with open-source Devito</Button>
    </div>
  </Section>
  <CaseStudies tone="base" posts={posts} />
  <TeamTeaser tone="surface" />
  <CTA />
</Base>
