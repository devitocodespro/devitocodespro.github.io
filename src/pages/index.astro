---
/*
 * Homepage — product umbrella (2026-06).
 * Presents the commercial product family on the open-source Devito core, co-equally,
 * and makes the differences + target audience explicit via the stack diagram, product
 * cards and comparison matrix. All sections are data-driven from src/data/products.ts,
 * so adding a product needs no template changes. DevitoPRO's deep capabilities now
 * live on /devitopro.
 *
 * Section order: Hero → Trust → Stack → Products → Compare → Benchmarks →
 *                CaseStudies → Team → CTA.
 */
import Base from '../layouts/Base.astro';
import HeroProducts from '../components/HeroProducts.astro';
import LogoBar from '../components/LogoBar.astro';
import Section from '../components/Section.astro';
import ProductStack from '../components/ProductStack.astro';
import ProductCards from '../components/ProductCards.astro';
import ProductComparison from '../components/ProductComparison.astro';
import Benchmarks from '../components/Benchmarks.astro';
import CaseStudies from '../components/CaseStudies.astro';
import TeamTeaser from '../components/TeamTeaser.astro';
import CTA from '../components/CTA.astro';
---
<Base>
  <HeroProducts />
  <LogoBar />
  <Section
    id="stack"
    tone="base"
    eyebrow="How it fits together"
    title="One stack, from kernels to complete inversion"
    intro="Open-source Devito generates the code. DevitoPRO makes wave-equation solves fast and portable. Higher-level SDKs and frameworks add complete FWI and imaging inversion on top — in Python, Julia and beyond."
  >
    <ProductStack />
  </Section>
  <Section
    id="products"
    tone="surface"
    eyebrow="Products"
    title="Pick the layer you need."
  >
    <ProductCards />
  </Section>
  <Section
    id="compare"
    tone="base"
    eyebrow="Which is right for you?"
    title="Compare the products"
    intro="They share one performance-portable core; they differ in how much of the inversion workflow you bring versus configure."
  >
    <ProductComparison />
  </Section>
  <Benchmarks tone="surface" />
  <CaseStudies tone="base" />
  <TeamTeaser tone="surface" />
  <CTA />
</Base>
