---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import LogoBar from '../components/LogoBar.astro';
import Trilemma from '../components/Trilemma.astro';
import Solution from '../components/Solution.astro';
import Benchmarks from '../components/Benchmarks.astro';
import UseCases from '../components/UseCases.astro';
import Section from '../components/Section.astro';
import FeatureTable from '../components/FeatureTable.astro';
import CaseStudies from '../components/CaseStudies.astro';
import TeamTeaser from '../components/TeamTeaser.astro';
import CTA from '../components/CTA.astro';
import Button from '../components/Button.astro';
import { featureIntro } from '../data/features';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => +new Date(b.data.date) - +new Date(a.data.date),
);
---
<Base>
  <Hero />
  <LogoBar />
  <Trilemma tone="surface" />
  <Solution tone="base" />
  <Benchmarks tone="surface" />
  <UseCases tone="base" />
  <Section
    id="compare"
    tone="surface"
    eyebrow="DevitoPRO vs open-source"
    title="Everything in Devito, plus what production needs."
    intro={featureIntro}
  >
    <FeatureTable condensed={true} />
    <div class="mt-8"><Button href="/features" variant="ghost">See the full comparison</Button></div>
  </Section>
  <CaseStudies tone="base" posts={posts} />
  <TeamTeaser tone="surface" />
  <CTA />
</Base>
