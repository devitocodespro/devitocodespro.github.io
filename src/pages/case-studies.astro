---
import Base from '../layouts/Base.astro';
import Section from '../components/Section.astro';
import CTA from '../components/CTA.astro';
import { caseStudies } from '../data/content';
import { getCollection } from 'astro:content';
import { withBase } from '../lib/url';

const posts = (await getCollection('blog')).sort(
  (a, b) => +new Date(b.data.date) - +new Date(a.data.date),
);
const fmt = (d: Date) =>
  new Date(d).toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' });
---
<Base title="Case studies" description="Customer stories, benchmarks and technical articles from Devito Codes.">
  <Section eyebrow="Proof" title="Case studies & technical articles" class="pt-28">
    <div class="mt-10 grid gap-6 md:grid-cols-2">
      {caseStudies.map((cs) => (
        <a href={cs.href} target="_blank" rel="noopener noreferrer" class="card p-7 hover:border-accent transition-colors">
          <p class="eyebrow">{cs.outlet}</p>
          <h3 class="mt-3 text-lg font-bold text-ink">{cs.title}</h3>
          <p class="mt-2 text-sm text-muted leading-relaxed">{cs.body}</p>
          <span class="mt-4 inline-block text-accent text-sm font-semibold">Read the story →</span>
        </a>
      ))}
      {posts.map((post) => (
        <a href={withBase(`/blog/${post.id}`)} class="card p-7 hover:border-accent transition-colors">
          <p class="eyebrow">{fmt(post.data.date)}</p>
          <h3 class="mt-3 text-lg font-bold text-ink">{post.data.title}</h3>
          {post.data.description && <p class="mt-2 text-sm text-muted leading-relaxed line-clamp-3">{post.data.description}</p>}
          <span class="mt-4 inline-block text-accent text-sm font-semibold">Read more →</span>
        </a>
      ))}
    </div>
  </Section>
  <CTA />
</Base>
