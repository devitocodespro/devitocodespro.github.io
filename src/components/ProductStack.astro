---
import { devitoCore, products } from '../data/products';
import { withBase } from '../lib/url';

// Layered "stack" diagram, driven entirely by src/data/products.ts: the inversion
// frameworks sit on the DevitoPRO engine, which sits on the open-source Devito core.
// Adding a product (with the right `tier`) flows in automatically. Pure HTML/CSS with
// theme tokens, so it tracks light/dark and stays responsive.
const frameworks = products.filter((p) => p.tier === 'framework');
const engine = products.find((p) => p.tier === 'engine');
const tier = 'block rounded-xl border text-center transition-colors';
---
<div class="mt-12 max-w-3xl mx-auto flex flex-col gap-3">
  {/* Top tier: inversion frameworks */}
  <p class="eyebrow text-center">Inversion frameworks</p>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
    {frameworks.map((f) => (
      <a href={withBase(f.href)} class={`${tier} border-accent/50 bg-accent/5 p-5 hover:border-accent`}>
        <span class="block font-bold text-ink">{f.name}</span>
        <span class="block mt-1 text-xs text-muted">{f.stackNote}</span>
      </a>
    ))}
  </div>

  <div class="text-center text-muted/60 text-xl leading-none" aria-hidden="true">▲</div>

  {/* Middle tier: the engine (highlighted) */}
  {engine && (
    <a href={withBase(engine.href)} class={`${tier} border-accent bg-accent/10 p-6 hover:brightness-105`}>
      <span class="block font-bold text-ink text-lg">{engine.name}</span>
      <span class="block mt-1 text-sm text-muted">{engine.stackNote}</span>
    </a>
  )}

  <div class="text-center text-muted/60 text-xl leading-none" aria-hidden="true">▲</div>

  {/* Base tier: open-source core */}
  <a href={devitoCore.href} target="_blank" rel="noopener noreferrer" class={`${tier} border-line bg-surface p-6 hover:border-accent`}>
    <span class="block font-bold text-ink text-lg">{devitoCore.name}</span>
    <span class="block mt-1 text-sm text-muted">{devitoCore.role}</span>
  </a>

  <p class="mt-2 text-center text-sm text-muted">
    One symbolic core. DevitoPRO accelerates the wave-equation solves; higher-level products build the inversion on top.
  </p>
</div>
