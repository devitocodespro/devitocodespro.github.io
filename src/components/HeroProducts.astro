---
import { productHero, products } from '../data/products';
import Button from './Button.astro';
// Umbrella hero for the homepage — frames the stack and the three products.
---
<section class="bg-surface border-b border-line">
  <div class="container-x pt-28 pb-16 md:pt-32 md:pb-20">
    <p class="font-mono text-xs uppercase tracking-[0.18em] text-accent">{productHero.eyebrow}</p>
    <h1 class="mt-5 max-w-5xl text-4xl md:text-6xl font-extrabold text-ink text-balance leading-[1.05]">
      {productHero.title}
    </h1>
    <p class="mt-6 max-w-3xl text-lg md:text-xl text-muted leading-relaxed">{productHero.subtitle}</p>

    {/* Three-product strip — names + one-liners, above the fold */}
    <dl class="mt-10 grid gap-4 sm:grid-cols-3 max-w-5xl">
      {products.map((p) => (
        <div class="border-l-2 border-accent/60 pl-4">
          <dt class="font-bold text-ink">{p.name}</dt>
          <dd class="mt-1 text-sm text-muted">{p.tagline}</dd>
        </div>
      ))}
    </dl>

    <div class="mt-10 flex flex-wrap gap-3">
      <Button href="/contact" variant="primary">Book a technical call</Button>
      <Button href="#compare" variant="ghost">Compare the products</Button>
    </div>
  </div>
</section>
