---
import { hero } from '../data/content';
import { site } from '../data/site';
import { withBase } from '../lib/url';
import Button from './Button.astro';
---
<!-- `isolate` is critical: forms a stacking context so the absolutely-positioned
     -z-10 image stays BEHIND content but ABOVE the section's bg-page. Without it
     the wavefield image is hidden by the opaque section background. -->
<section class="relative overflow-hidden bg-page isolate">
  <div class="absolute inset-0 -z-10">
    <img src={withBase(hero.image)} alt="" aria-hidden="true" class="w-full h-full object-cover" style="opacity: var(--hero-img-opacity, 0.25)" />
    <div class="absolute inset-0 bg-gradient-to-b from-base/70 via-base/85 to-base"></div>
  </div>
  <div class="container-x pt-24 pb-20 md:pt-32 md:pb-28">
    <p class="eyebrow mb-5">{hero.eyebrow}</p>
    <h1 class="max-w-4xl text-4xl md:text-6xl font-extrabold text-ink text-balance leading-[1.05]">
      {hero.title}
    </h1>
    <p class="mt-6 max-w-2xl text-lg md:text-xl text-muted leading-relaxed">{hero.subtitle}</p>
    {hero.supporting && (
      <p class="mt-3 max-w-2xl text-base text-muted/80 leading-relaxed">{hero.supporting}</p>
    )}
    {hero.differentiator && (
      <div class="mt-7 inline-flex items-center gap-2 rounded-full border border-accent/40 bg-accent/10 px-4 py-2 text-sm font-semibold text-accent">
        <span class="w-1.5 h-1.5 rounded-full bg-accent" aria-hidden="true"></span>
        {hero.differentiator}
      </div>
    )}
    <div class="mt-8 flex flex-wrap gap-3">
      <Button href={site.primaryCta.href} variant="primary">{site.primaryCta.label}</Button>
      <Button href={site.secondaryCta.href} variant="ghost">{site.secondaryCta.label}</Button>
    </div>
  </div>
</section>
