---
import Section from './Section.astro';
import { caseStudies } from '../data/content';
import { withBase } from '../lib/url';
import type { CollectionEntry } from 'astro:content';
interface Props { tone?: 'base' | 'surface'; posts?: CollectionEntry<'blog'>[]; }
const { tone = 'surface', posts = [] } = Astro.props;
// Per team feedback (2026-05-26) we don't surface post dates in listings —
// our cadence is uneven, and the date in the post header is enough context once opened.
const visiblePosts = posts.filter((p) => !p.data.draft);
---
<Section id="case-studies" tone={tone} eyebrow="Proof" title="Results — in the field and in the press.">
  <div class="mt-10 grid gap-6 lg:grid-cols-3">
    {caseStudies.map((cs) => (
      <a href={cs.href} target="_blank" rel="noopener noreferrer" class="card p-7 hover:border-accent transition-colors">
        <p class="eyebrow">{cs.outlet}</p>
        <h3 class="mt-3 text-lg font-bold text-ink">{cs.title}</h3>
        <p class="mt-2 text-sm text-muted leading-relaxed">{cs.body}</p>
        <span class="mt-4 inline-block text-accent text-sm font-semibold">Read the story →</span>
      </a>
    ))}
    {visiblePosts.slice(0, 2).map((post) => (
      <a href={withBase(`/blog/${post.id}`)} class="card p-7 hover:border-accent transition-colors">
        <p class="eyebrow">From the blog</p>
        <h3 class="mt-3 text-lg font-bold text-ink">{post.data.title}</h3>
        <p class="mt-2 text-sm text-muted leading-relaxed line-clamp-3">{post.data.description}</p>
        <span class="mt-4 inline-block text-accent text-sm font-semibold">Read more →</span>
      </a>
    ))}
  </div>
</Section>
