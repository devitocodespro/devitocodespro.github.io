---
import { site } from '../data/site';
import { withBase } from '../lib/url';
import Button from './Button.astro';
---
<header class="sticky top-0 z-50 backdrop-blur bg-base/80 border-b border-line/70">
  <nav class="container-x flex items-center justify-between h-16">
    <a href={withBase('/')} class="flex items-center gap-2.5 font-extrabold text-ink tracking-tight">
      <span class="inline-block w-2.5 h-2.5 rounded-sm bg-accent"></span>
      Devito<span class="text-muted font-semibold">Codes</span>
    </a>

    <input type="checkbox" id="navtoggle" class="peer hidden" aria-hidden="true" />

    <div class="hidden md:flex items-center gap-7 text-sm font-medium text-muted">
      {site.nav.map((item) => (
        <a href={withBase(item.href)} class="hover:text-ink transition-colors">{item.label}</a>
      ))}
      <Button href={site.primaryCta.href} variant="primary" class="text-sm">{site.primaryCta.label}</Button>
    </div>

    <label for="navtoggle" class="md:hidden inline-flex items-center justify-center w-10 h-10 rounded-lg border border-line text-ink cursor-pointer select-none" aria-label="Toggle menu">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
    </label>

    <div class="absolute top-16 inset-x-0 hidden peer-checked:block md:hidden bg-surface border-b border-line">
      <div class="container-x py-4 flex flex-col gap-1">
        {site.nav.map((item) => (
          <a href={withBase(item.href)} class="py-2 text-muted hover:text-ink transition-colors">{item.label}</a>
        ))}
        <Button href={site.primaryCta.href} variant="primary" class="mt-2 justify-center">{site.primaryCta.label}</Button>
      </div>
    </div>
  </nav>
</header>
