---
import { site } from '../data/site';
import { withBase } from '../lib/url';
import Button from './Button.astro';
---
<header class="sticky top-0 z-50 backdrop-blur bg-base/80 border-b border-line/70">
  <nav class="container-x flex items-center justify-between h-16">
    <a href={withBase('/')} class="flex items-center gap-2.5 font-medium text-ink tracking-tight">
      <img src={withBase('/assets/img/devito-logo.svg')} alt="Devito Codes" class="h-8 w-auto" />
      Devito Codes
    </a>

    {/* Hidden checkbox controls mobile menu visibility via the peer-checked sibling pattern. */}
    <input type="checkbox" id="navtoggle" class="peer hidden" aria-hidden="true" />

    <div class="flex items-center gap-3">
      <div class="hidden md:flex items-center gap-7 text-sm font-medium text-muted">
        {site.nav.map((item) => (
          <a href={withBase(item.href)} class="hover:text-ink transition-colors">{item.label}</a>
        ))}
        <Button href={site.primaryCta.href} variant="primary" class="text-sm">{site.primaryCta.label}</Button>
      </div>

      <button
        id="theme-toggle"
        type="button"
        aria-label="Toggle dark mode"
        title="Toggle light / dark mode"
        class="inline-flex items-center justify-center w-10 h-10 rounded-lg border border-line text-muted hover:text-accent hover:border-accent transition-colors cursor-pointer"
      >
        <svg class="theme-icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
        <svg class="theme-icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4" />
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
        </svg>
      </button>

      <label for="navtoggle" class="md:hidden inline-flex items-center justify-center w-10 h-10 rounded-lg border border-line text-ink cursor-pointer select-none" aria-label="Toggle menu">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
      </label>
    </div>

    <div class="absolute top-16 inset-x-0 hidden peer-checked:block md:hidden bg-surface border-b border-line">
      <div class="container-x py-4 flex flex-col gap-1">
        {site.nav.map((item) => (
          <a href={withBase(item.href)} class="py-2 text-muted hover:text-ink transition-colors">{item.label}</a>
        ))}
        <Button href={site.primaryCta.href} variant="primary" class="mt-2 justify-center">{site.primaryCta.label}</Button>
      </div>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('theme-toggle');
  const root = document.documentElement;
  const setPressed = () => btn && btn.setAttribute('aria-pressed', root.dataset.theme === 'dark' ? 'true' : 'false');
  setPressed();
  btn?.addEventListener('click', () => {
    const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
    root.dataset.theme = next;
    try { localStorage.setItem('theme', next); } catch (e) {}
    setPressed();
  });
</script>
