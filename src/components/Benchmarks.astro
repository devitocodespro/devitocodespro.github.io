---
import Section from './Section.astro';
import { benchmarks } from '../data/content';
import { withBase } from '../lib/url';
interface Props { tone?: 'base' | 'surface'; }
const { tone = 'surface' } = Astro.props;
---
<Section id="performance" tone={tone} eyebrow={benchmarks.eyebrow} title={benchmarks.title} intro={benchmarks.intro}>
  <div class="mt-12 grid gap-6 sm:grid-cols-2">
    {benchmarks.cards.map((c) => (
      <figure class="card overflow-hidden flex flex-col">
        <a
          href={withBase(c.image)}
          target="_blank"
          rel="noopener noreferrer"
          title="Click to view full size"
          class="block bg-base/40 p-3 border-b border-line hover:bg-base/60 transition-colors"
        >
          <img src={withBase(c.image)} alt={c.title} loading="lazy" class="w-full h-80 object-contain" />
        </a>
        <figcaption class="p-6">
          <h3 class="font-bold text-ink">{c.title}</h3>
          <p class="mt-2 text-sm text-muted leading-relaxed">{c.body}</p>
          <p class="mt-3 text-[11px] font-mono uppercase tracking-wider text-muted/70">↗ click chart for full size</p>
        </figcaption>
      </figure>
    ))}
  </div>
</Section>
